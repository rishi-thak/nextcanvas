# ───────────────────────── Dependencies ─────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# ───────────────────────── Build output ─────────────────────────
# TypeScript build output — regenerated by `npm run build`.
# (The prebuilt wasm in nextcanvas/swc/ IS committed on purpose.)
nextcanvas/dist/
dist/
build/
out/

# ───────────────────────── Next.js ──────────────────────────────
.next/
next-env.d.ts
.vercel/

# ───────────────────────── TypeScript ───────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ───────────────────────── Rust / SWC plugin ────────────────────
# Build artifacts only — Cargo.lock and the committed .wasm are kept.
target/
**/*.rs.bk

# ───────────────────────── Package tooling ──────────────────────
*.tgz
.npm/
.eslintcache
.cache/
.turbo/
coverage/

# ───────────────────────── Logs ─────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ───────────────────────── Env / secrets ────────────────────────
.env
.env.*
!.env.example

# ───────────────────────── Editors / OS ─────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
